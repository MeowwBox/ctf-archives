diff --git a/kernel/sysshm.c b/kernel/sysshm.c
new file mode 100644
index 0000000..f921876
--- /dev/null
+++ b/kernel/sysshm.c
@@ -0,0 +1,119 @@
+#include "types.h"
+#include "riscv.h"
+#include "defs.h"
+#include "param.h"
+#include "memlayout.h"
+#include "spinlock.h"
+#include "proc.h"
+
+#define NSHM 4
+
+struct shm_region {
+  int used;
+  uint64 pa;
+  struct spinlock lock;
+};
+
+static struct shm_region shm_table[NSHM];
+
+void
+shminit(void)
+{
+  for(int i = 0; i < NSHM; i++){
+    initlock(&shm_table[i].lock, "shm");
+    shm_table[i].used = 0;
+    shm_table[i].pa = 0;
+  }
+}
+
+uint64
+sys_shmcreate(void)
+{
+  for(int i = 0; i < NSHM; i++){
+    acquire(&shm_table[i].lock);
+    if(!shm_table[i].used){
+      void *pa = kalloc();
+      if(pa == 0){
+        release(&shm_table[i].lock);
+        return -1;
+      }
+      memset(pa, 0, PGSIZE);
+      shm_table[i].pa = (uint64)pa;
+      shm_table[i].used = 1;
+      release(&shm_table[i].lock);
+      return i;
+    }
+    release(&shm_table[i].lock);
+  }
+  return -1;
+}
+
+uint64
+sys_shmattach(void)
+{
+  int key;
+  uint64 va;
+
+  argint(0, &key);
+  argaddr(1, &va);
+
+  if(key < 0 || key >= NSHM)
+    return -1;
+  if(va % PGSIZE != 0)
+    return -1;
+  if(va >= TRAPFRAME)
+    return -1;
+
+  struct proc *p = myproc();
+  if(p->shm_key >= 0)
+    return -1;
+
+  struct shm_region *s = &shm_table[key];
+  acquire(&s->lock);
+  if(!s->used){
+    release(&s->lock);
+    return -1;
+  }
+
+  uint64 pa = s->pa;
+  release(&s->lock);
+
+  if(mappages(p->pagetable, va, PGSIZE, pa, PTE_R | PTE_W | PTE_U) != 0)
+    return -1;
+
+  p->shm_key = key;
+  p->shm_va = va;
+  return 0;
+}
+
+uint64
+sys_shmdetach(void)
+{
+  int key;
+  argint(0, &key);
+
+  if(key < 0 || key >= NSHM)
+    return -1;
+
+  struct proc *p = myproc();
+  if(p->shm_key != key)
+    return -1;
+
+  struct shm_region *s = &shm_table[key];
+  acquire(&s->lock);
+  if(!s->used){
+    release(&s->lock);
+    return -1;
+  }
+
+  uvmunmap(p->pagetable, p->shm_va, 1, 0);
+  p->shm_key = -1;
+  p->shm_va = 0;
+
+  kfree((void*)s->pa);
+  s->pa = 0;
+  s->used = 0;
+
+  release(&s->lock);
+  return 0;
+}
