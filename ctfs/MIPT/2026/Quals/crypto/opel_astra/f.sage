import os

flag = b""
m = int.from_bytes(flag + os.urandom(112-len(flag)), 'big')

for i in range(2):
    n = random_prime(2^512) * random_prime(2^512)
    assert m < n
    b = random_prime(n)
    ct = (m*m + b*m) % n
    print(f"c{i}, n{i}, b{i} = ({ct}, {n}, {b})")

# c0, n0, b0 = (, , )
# c1, n1, b1 = (, , )
